name='winegui'
version='3.0.1'
release=1
summary='WineGUI — user-friendly Wine manager'
summary_ru='WineGUI — удобный менеджер Wine'
group='Emulators'
desc='WineGUI is a user-friendly WINE manager with graphical interface. Create, manage and configure Wine bottles easily.'
desc_ru='WineGUI — удобный менеджер WINE с графическим интерфейсом. Легко создавайте, управляйте и настраивайте бутылки Wine.'
homepage='https://gitlab.melroy.org/melroy/winegui'
maintainer='Melroy van den Berg <https://gitlab.melroy.org/melroy>'

architectures=('amd64')

license=('AGPL-3.0')

deps=()
deps_debian=('wine' 'cabextract' 'p7zip-full' 'unzip' 'wget' 'zenity' 'libgtkmm-4.0-0')
deps_ubuntu=('wine' 'cabextract' 'p7zip-full' 'unzip' 'wget' 'zenity' 'libgtkmm-4.0-0')
deps_fedora=('wine' 'cabextract' 'p7zip' 'unzip' 'wget' 'zenity' 'gtkmm4.0')
deps_arch=('wine' 'cabextract' 'p7zip' 'unzip' 'wget' 'zenity' 'gtkmm-4.0')
deps_opensuse=('wine' 'cabextract' 'p7zip-full' 'unzip' 'wget' 'zenity' 'gtkmm4')
deps_altlinux=('wine' 'cabextract' 'p7zip' 'unzip' 'wget' 'zenity' 'libgtkmm4')

build_deps=()
build_deps_altlinux=('cmake' 'ninja-build' 'gcc-c++' 'libgtkmm4-devel' 'pkg-config' 'libjson-glib-devel')
build_deps_debian=('cmake' 'ninja-build' 'g++' 'libgtkmm-4.0-dev' 'pkg-config' 'libjson-glib-dev')
build_deps_ubuntu=('cmake' 'ninja-build' 'g++' 'libgtkmm-4.0-dev' 'pkg-config' 'libjson-glib-dev')
build_deps_fedora=('cmake' 'ninja-build' 'gcc-c++' 'gtkmm4.0-devel' 'pkgconfig' 'json-glib-devel')
build_deps_arch=('cmake' 'ninja' 'gcc' 'gtkmm-4.0' 'pkgconf' 'json-glib')

auto_reqprov_method="dirty"
auto_req=0
auto_prov=0

sources=(
    "https://github.com/winegui/WineGUI/archive/refs/tags/v${version}.tar.gz"
)

checksums=('SKIP')

scripts=(
    ['postinstall']='postinstall.sh'
    ['postremove']='postremove.sh'
)

prepare() {
    cd "${srcdir}/WineGUI-${version}"
    
    # Создаём version.txt для сборки (без перевода строки)
    printf '%s' "${version}" > version.txt
}

build() {
    cd "${srcdir}/WineGUI-${version}"
    
    cmake -GNinja -B build \
        -DCMAKE_BUILD_TYPE=Release \
        -DCMAKE_INSTALL_PREFIX=/usr \
        -DGSETTINGS_COMPILE:BOOL=FALSE \
        -DCHECK_FOR_UPDATE=OFF
    
    cmake --build ./build --config Release
}

package() {
    cd "${srcdir}/WineGUI-${version}"
    
    DESTDIR="${pkgdir}" cmake --install ./build
    
    # Лицензия
    install -Dm644 LICENSE "${pkgdir}/usr/share/licenses/${name}/LICENSE"
    
    # Установка иконок (CMake их не устанавливает в системный каталог)
    install -Dm644 misc/winegui.png "${pkgdir}/usr/share/icons/hicolor/48x48/apps/winegui.png"
    install -Dm644 misc/winegui.svg "${pkgdir}/usr/share/icons/hicolor/scalable/apps/winegui.svg"
}

files() {
    files-find \
        "/usr/bin/winegui" \
        "/usr/share/applications/winegui.desktop" \
        "/usr/share/icons/hicolor/48x48/apps/winegui.png" \
        "/usr/share/icons/hicolor/scalable/apps/winegui.svg" \
        "/usr/share/glib-2.0/schemas/org.melroy.winegui.gschema.xml" \
        "/usr/share/winegui/**/*" \
        "/usr/share/licenses/winegui/*"
}
